# URL de l'API backend. En Expo Go sur un telephone physique, "localhost" ne
# fonctionne PAS : remplacez par l'adresse IP locale de votre ordinateur
# (ex: http://192.168.1.42:8010), visible avec `ipconfig` (Windows).
# Sur simulateur Android, utilisez http://10.0.2.2:8010
EXPO_PUBLIC_API_URL=http://localhost:8010
